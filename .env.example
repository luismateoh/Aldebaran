# =========================================
# Aldebaran - Local environment template
# Copy this file to .env.local and fill it
# =========================================

# Firebase Client SDK (required)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (required for server routes)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# Admin UX / notifications
NEXT_PUBLIC_ADMIN_EMAIL=

# AI enhancement (optional)
GROQ_API_KEY=

# AI Harness - Planner (Kimi 2.7 Code via OpenRouter)
# Obtén tu API key en https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_PLANNER_MODEL=moonshotai/kimi-2-7-code-thinking
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AI Harness - Worker (modelo rápido para sub-agentes)
# Por defecto usa GROQ_API_KEY con llama-3.1-8b-instant
GROQ_WORKER_MODEL=llama-3.1-8b-instant

# EmailJS (optional)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Vercel / deploy convenience (optional locally)
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
